LLM_PROVIDER=gpt-4o-mini
LLM_API_TOKEN=sk-xxx
LLM_BASE_URL=https://fastcn.poloapi.com/v1

REDIS_BLOOM_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_BLOOM_KEY_PREFIX=crawl:detail
REDIS_BLOOM_ERROR_RATE=0.001
REDIS_BLOOM_CAPACITY=100000
REDIS_SOCKET_TIMEOUT=3

MEILI_URL=http://localhost:7700
MEILI_API_KEY=master-key

MEILI_HYBRID_ENABLED=true
MEILI_HYBRID_EMBEDDER_NAME=openai-emb
MEILI_HYBRID_ENDPOINT=https://api.openai.com/v1/embeddings
MEILI_HYBRID_API_KEY=sk-xxx
MEILI_HYBRID_MODEL=text-embedding-3-small
MEILI_HYBRID_DIMENSIONS=1536
MEILI_HYBRID_INDEXES=industry_news,competitor_news,trade_shows
MEILI_HYBRID_DOCUMENT_TEMPLATE={{doc.title}}\n{{doc.summary}}\n{{doc.cleaned_content}}
