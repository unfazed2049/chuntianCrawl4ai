{
  "workspace": "default",
  "sites": [
    {
      "name": "中国农业大学",

      "sections": [
        {
          "name": "科学研究",
          "mode": "list",
          "prompt": "news_article",

          "list": {
            "pagination": {
              "type": "url_template",
              "url_template": "https://news.cau.edu.cn/kxyj/index{page}.htm",
              "page_start": 1,
              "page_end": 3
            },
            "link_filter_pattern": "[a-f0-9]{32}\\.htm$"
          }
        },

        {
          "name": "关于我们",
          "mode": "single",

          "single": {
            "url": "https://news.cau.edu.cn/xxgk/index.htm"
          }
        }
      ]
    },

    {
      "name": "FoodexWorld",

      "sections": [
        {
          "name": "内部展会",
          "mode": "list",
          "prompt": "product_page",

          "list": {
            "pagination": {
              "type": "js_pagination",
              "url": "https://www.foodexworld.com/internalexpo",
              "total_pages": 3,
              "wait_for_first": "js:() => { const items = document.querySelectorAll('div.expo_box'); return items.length > 0; }",
              "js_next_page": "(() => { const items = document.querySelectorAll('div.expo_box'); items.forEach(el => el.remove()); const btns = document.querySelectorAll('ul.pagination > li:not(.disabled)'); if (btns[{page}]) { btns[{page}].firstChild.click(); } })()",
              "wait_for_next": "js:() => { const items = document.querySelectorAll('div.expo_box'); return items.length > 0; }"
            },
            "link_filter_pattern": "/expo/\\w+"
          },

          "crawler_config": {
            "css_selector": "div.expo_index",
            "wait_for": "js:() => { const items = document.querySelectorAll('div.expo_box'); return items.length > 0; }",
            "content_filter_threshold": 0.8
          }
        }
      ]
    }
  ]
}
